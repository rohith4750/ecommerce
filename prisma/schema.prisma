datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Channel {
  WEBSITE
  AMAZON
  FLIPKART
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role          @default(USER)
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  cartItems    CartItem[]
  wishlist     WishlistItem[]
}

model Product {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  sku             String        @unique
  description     String        @db.Text
  price           Float
  salePrice       Float?
  discountPercent Float?        // Calculated value
  images          String[]      // List of image URLs
  category        String        // Silk, Cotton, Georgette, etc.
  type            String        // Banarasi, Kanjeevaram, etc.
  color           String[]      // Array of colors
  size            String[]      // Size options (e.g. Free Size, 5.5m)
  gender          String        @default("Women")
  stock           Int
  amazonASIN      String?
  flipkartFSN     String?
  isFeatured      Boolean       @default(false)
  ratingAverage   Float         @default(0.0)
  ratingCount     Int           @default(0)
  tags            String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
}

model Order {
  id              String        @id @default(uuid())
  orderId         String        @unique // Format: SR-YYYYMMDD-XXXX
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  items           Json          // Array of { productId, name, price, qty, image }
  shippingAddress Json          // { name, phone, address, city, state, pincode }
  paymentMethod   String        @default("razorpay")
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  orderStatus     OrderStatus   @default(PLACED)
  trackingNumber  String?
  channel         Channel       @default(WEBSITE)
  totalAmount     Float
  discount        Float         @default(0.0)
  couponCode      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Discount {
  id           String       @id @default(uuid())
  code         String       @unique
  type         DiscountType @default(PERCENTAGE)
  value        Float
  minCartValue Float        @default(0.0)
  isActive     Boolean      @default(true)
  startDate    DateTime
  endDate      DateTime
  category     String?      // Category restriction (e.g. Silk)
  usageCount   Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
